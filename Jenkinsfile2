pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        DOCKERHUB_USER = 'mahesh2452'
        DOCKER_REPO    = 'usermanagement'
        IMAGE_TAG      = "${BUILD_NUMBER}"

        DOCKER_IMAGE  = "${DOCKERHUB_USER}/${DOCKER_REPO}:${IMAGE_TAG}"
        DOCKER_LATEST = "${DOCKERHUB_USER}/${DOCKER_REPO}:latest"

        GIT_REPO_URL = 'https://github.com/Mahesh1-code141/Managenet_Credentials.git'
        GIT_BRANCH   = 'main'

        K8S_NAMESPACE = 'mahesh'
        AWS_REGION    = "ap-south-1"
        CLUSTER_NAME  = "mycluster"

        SONAR_SCANNER = tool 'sonar-scanner'   // ✅ Correct tool name
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO_URL}"
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                python3 -m pip install --upgrade pip
                pip3 install -r requirements.txt
                '''
            }
        }

        stage('Test & Coverage') {
            steps {
                sh '''
                pip3 install pytest pytest-cov
                pytest --cov=app --cov-report=xml:coverage.xml test_app.py
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sq') {
                    sh """
                    ${SONAR_SCANNER}/bin/sonar-scanner \
                    -Dsonar.projectKey=3-tier-user-management-app \
                    -Dsonar.sources=. \
                    -Dsonar.python.coverage.reportPaths=coverage.xml
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Artifact') {
            steps {
                sh '''
                pip3 install build
                python3 -m build
                '''
            }
        }

        stage('Upload to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexuscred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                    python3 -m twine upload \
                    --repository-url http://3.110.159.152:8081/repository/python/ \
                    -u $USER -p $PASS dist/*
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $DOCKER_IMAGE -t $DOCKER_LATEST .
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    docker push $DOCKER_IMAGE
                    docker push $DOCKER_LATEST
                    docker logout
                    '''
                }
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                sh '''
                aws eks update-kubeconfig --region $AWS_REGION --name $CLUSTER_NAME
                kubectl get nodes
                '''
            }
        }

        stage('Deploy Monitoring') {
            steps {
                sh '''
                helm repo add prometheus-community https://prometheus-community.github.io/helm-charts || true
                helm repo update

                helm upgrade --install monitoring prometheus-community/kube-prometheus-stack \
                --namespace monitoring --create-namespace \
                --set grafana.service.type=LoadBalancer
                '''
            }
        }

        stage('Deploy Application') {
            steps {
                sh '''
                kubectl apply -f namespace.yml
                kubectl apply -f projectdeploy.yml
                '''
            }
        }

        stage('Get App URL') {
            steps {
                script {
                    def url = sh(
                        script: '''
                        kubectl get svc myuserapp-service -n mahesh \
                        -o jsonpath="{.status.loadBalancer.ingress[0].hostname}"
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "App URL: http://${url}"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS"
        }
        failure {
            echo "Pipeline FAILED"
        }
        always {
            sh 'docker system prune -f || true'  // ✅ cleanup
        }
    }
}
